{
  "display_information": {
    "name": "Fulfillment Assistant",
    "description": "Tracks fulfillment requests, due dates, and the shipping calendar",
    "background_color": "#1f2937"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": true
    },
    "bot_user": {
      "display_name": "Fulfillment Assistant",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/request",
        "url": "https://fulfillment-assistant.brandon-taylor2399.workers.dev/slack/commands",
        "description": "Create a fulfillment request",
        "usage_hint": "[what you need] [due <date>] [!high]",
        "should_escape": false
      },
      {
        "command": "/requests",
        "url": "https://fulfillment-assistant.brandon-taylor2399.workers.dev/slack/commands",
        "description": "List open requests",
        "usage_hint": "[done]",
        "should_escape": false
      },
      {
        "command": "/done",
        "url": "https://fulfillment-assistant.brandon-taylor2399.workers.dev/slack/commands",
        "description": "Mark a request complete",
        "usage_hint": "<request id>",
        "should_escape": false
      },
      {
        "command": "/edit",
        "url": "https://fulfillment-assistant.brandon-taylor2399.workers.dev/slack/commands",
        "description": "Edit a request: due date, priority, company, assignee, title",
        "usage_hint": "<id> [due <date>] [!high] [for:company] [assign @person]",
        "should_escape": true
      },
      {
        "command": "/customer",
        "url": "https://fulfillment-assistant.brandon-taylor2399.workers.dev/slack/commands",
        "description": "Manage the customer list shown in the /request form",
        "usage_hint": "[add <name> | link <name> | <companies> | remove | list]",
        "should_escape": false
      },
      {
        "command": "/company",
        "url": "https://fulfillment-assistant.brandon-taylor2399.workers.dev/slack/commands",
        "description": "Manage the company list shown in the /request form",
        "usage_hint": "[add <name> | remove <name> | list]",
        "should_escape": false
      },
      {
        "command": "/category",
        "url": "https://fulfillment-assistant.brandon-taylor2399.workers.dev/slack/commands",
        "description": "Manage ticket #categories (receiving, ship, fulfillment, ...)",
        "usage_hint": "[add <name> | remove <name> | list]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": ["commands", "chat:write", "chat:write.public", "im:write", "files:read", "files:write"]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://fulfillment-assistant.brandon-taylor2399.workers.dev/slack/events",
      "bot_events": ["app_home_opened"]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://fulfillment-assistant.brandon-taylor2399.workers.dev/slack/interactions"
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
