{
  "name": "fulfillment-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "Slack app for tracking fulfillment requests, due dates, and shipping schedules",
  "scripts": {
    "postinstall": "npm --prefix board install",
    "build:board": "npm --prefix board run build",
    "dev": "npm run build:board && wrangler dev",
    "deploy": "npm run build:board && wrangler deploy",
    "types": "wrangler types",
    "check": "wrangler types && tsc --noEmit && npm --prefix board run check",
    "db:create": "wrangler d1 create fulfillment-db",
    "db:schema": "wrangler d1 execute fulfillment-db --remote --file=schema.sql"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "wrangler": "^4.0.0"
  }
}
